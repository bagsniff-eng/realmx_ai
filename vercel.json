{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "node_modules/.prisma/client/**",
      "regions": ["bom1"]
    }
  },
  "rewrites": [
    {
      "source": "/api/auth/google/callback",
      "destination": "/api/auth-callback?provider=google"
    },
    {
      "source": "/api/auth/github/callback",
      "destination": "/api/auth-callback?provider=github"
    },
    {
      "source": "/api/auth/discord/callback",
      "destination": "/api/auth-callback?provider=discord"
    },
    {
      "source": "/api/auth/twitter/callback",
      "destination": "/api/auth-callback?provider=twitter"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
